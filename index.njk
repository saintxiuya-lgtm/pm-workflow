---
permalink: index.html
eleventyComputed:
  title: ""
  description: "{{ site.description }}"
---
{% extends "_includes/base.njk" %}

{% block content %}
<!-- Hero -->
<section class="hero">
  <div class="container">
    <p class="hero-eyebrow">一个产品经理的笔记</p>
    <h1>工作流参考</h1>
    <p class="hero-desc">
      从想法到上线的六个阶段，每个阶段回答一个关键问题。<br>
      配套的工具和方法按场景整理，需要时来查就行。
    </p>
    <p class="hero-meta">共 6 个阶段 · 40+ 个技能 · 14 个工具</p>
  </div>
</section>

<!-- Phase List (narrow, reading-friendly) -->
<section class="container">
  <div class="phase-list">
    {% for phase in phases %}
    <a href="/{{ phase.id }}/" class="phase-list-item" data-phase="{{ phase.id }}">
      <span class="phase-list-num">{{ loop.index }}</span>
      <div class="phase-list-body">
        <div class="phase-list-header">
          <h3>{{ phase.name }}</h3>
          <span class="phase-list-short">{{ phase.short }}</span>
        </div>
        <p class="phase-list-question">「{{ phase.question }}」</p>
        <p class="phase-list-output">产出：{{ phase.outputs | join(" · ") }}</p>
      </div>
      <span class="phase-list-arrow" aria-hidden="true">→</span>
    </a>
    {% endfor %}
  </div>
</section>

<!-- Quick Start -->
<section class="container">
  <div class="quick-start">
    <h2>常见场景</h2>
    <div class="quick-start-grid">
      <div class="quick-start-item">
        <span class="qs-command">日常需求</span>
        <span class="qs-desc"><code>/prd</code> + <code>/user-stories</code> 快速出需求文档</span>
      </div>
      <div class="quick-start-item">
        <span class="qs-command">模糊想法</span>
        <span class="qs-desc">prd-writer 概念版引导，先对齐方向</span>
      </div>
      <div class="quick-start-item">
        <span class="qs-command">Vibe Coding</span>
        <span class="qs-desc">vibe-prd-writer 出可执行 PRD</span>
      </div>
      <div class="quick-start-item">
        <span class="qs-command">AI 产品</span>
        <span class="qs-desc">ai-agent-prd-writer 专项处理</span>
      </div>
      <div class="quick-start-item">
        <span class="qs-command">开会</span>
        <span class="qs-desc"><code>/meeting-brief</code> → <code>/meeting-recap</code></span>
      </div>
      <div class="quick-start-item">
        <span class="qs-command">定目标</span>
        <span class="qs-desc"><code>/okr-writer</code> → <code>/okr-grader</code></span>
      </div>
    </div>
  </div>
</section>
{% endblock %}
