<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/search.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.title }}{% endif %}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:site_name" content="{{ site.name }}">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.title }}{% endif %}">
  <meta name="twitter:description" content="{{ description or site.description }}">

  <!-- Canonical -->
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ site.name }}",
    "description": "{{ site.description }}",
    "url": "{{ site.url }}"
    {%- if breadcrumb %},
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "首页", "item": "{{ site.url }}/"}
        {%- for bc in breadcrumb %},
        {"@type": "ListItem", "position": {{ loop.index + 1 }}, "name": "{{ bc.name }}", "item": "{{ site.url }}{{ bc.href }}"}
        {%- endfor %}
      ]
    }
    {%- endif %}
  }
  </script>
</head>
<body>
  <a href="#main-content" class="skip-link">跳转到主内容</a>

  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <a href="/">{{ site.name }}</a>
    </div>

    <nav class="sidebar-section">
      <div class="sidebar-section-title">工作流</div>
      <ul class="sidebar-nav">
        {%- for p in phases %}
        <li>
          <a href="/{{ p.id }}/"
             class="{% if page.url == '/' + p.id + '/' %}active{% endif %}">
            <span class="phase-dot dot-{{ p.id }}"></span>
            {{ p.name }}
          </a>
        </li>
        {%- endfor %}
      </ul>
    </nav>

    <nav class="sidebar-section">
      <div class="sidebar-section-title">工具</div>
      <ul class="sidebar-nav">
        <li>
          <a href="/tools/"
             class="{% if page.url == '/tools/' %}active{% endif %}">
            全部工具
          </a>
        </li>
      </ul>
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-actions">
        <button class="sidebar-action-btn" data-action="search" aria-label="搜索">搜索</button>
        <button class="sidebar-action-btn theme-toggle" aria-label="切换主题">暗色</button>
      </div>
      <div class="sidebar-footer-text">{{ site.footer | safe }}</div>
    </div>
  </aside>

  <!-- Mobile menu toggle -->
  <button class="menu-toggle" id="menu-toggle" aria-label="打开导航" aria-expanded="false">☰</button>

  <!-- Main content -->
  <main class="content" id="main-content">
    {% block content %}{{ content | safe }}{% endblock %}
  </main>

  {% include "footer.njk" %}

  <!-- Search Modal -->
  <div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="搜索技能和工具">
    <div class="search-box">
      <div class="search-input-wrap">
        <input type="text" id="search-input" placeholder="搜索技能、命令、关键词…" autocomplete="off" spellcheck="false">
        <span class="search-kbd">ESC</span>
        <button class="search-close" aria-label="关闭搜索">关闭</button>
      </div>
      <div id="search-results" class="search-results"></div>
    </div>
  </div>

  <script src="/js/search-data.js"></script>
  <script src="/js/search.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
