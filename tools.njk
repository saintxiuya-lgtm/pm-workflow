---
permalink: tools/index.html
eleventyComputed:
  title: "跨阶段工具"
  description: "这些工具不属于某一个特定阶段，而是贯穿产品经理的日常工作，随时可用。"
  breadcrumb:
    - name: "工具"
      href: "/tools/"
---
{% extends "_includes/base.njk" %}

{% block content %}
<div class="container phase-page">
  <div class="page-header">
    <div class="breadcrumb">
      <a href="/">首页</a>
      <span aria-hidden="true">/</span>
      <span>工具</span>
    </div>
    <h1>跨阶段工具</h1>
    <p class="page-desc">这些工具不属于某一个特定阶段，而是贯穿产品经理的日常工作，随时可用。</p>
  </div>

  {% for section in tools.sections %}
  <section class="phase-section">
    <h2>{{ section.title }}</h2>
    <div class="skill-list">
      {% for tool in section.items %}
      <div class="skill-item">
        <div class="skill-item-header">
          <span class="skill-item-cmd">{{ tool.cmd }}</span>
          <span class="skill-item-name">{{ tool.title }}</span>
        </div>
        <p class="skill-item-desc">{{ tool.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endfor %}

  <div class="phase-nav">
    <a href="/">
      <span class="nav-label">{{ tools.pageNav.prev.label }}</span>
      <span class="nav-title">{{ tools.pageNav.prev.title }}</span>
    </a>
    <a href="/{{ phases[0].id }}/">
      <span class="nav-label">{{ tools.pageNav.next.label }}</span>
      <span class="nav-title">{{ tools.pageNav.next.title }}</span>
    </a>
  </div>
</div>
{% endblock %}
