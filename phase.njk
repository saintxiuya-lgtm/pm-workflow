---
pagination:
  data: collections.phasePages
  size: 1
  alias: phase
permalink: "/{{ phase.id }}/index.html"
title: "{{ phase.name }}"
breadcrumb:
  - name: "首页"
    href: "/"
  - name: "{{ phase.name }}"
    href: "{{ page.url }}"
description: "{{ phase.question }} — {{ phase.name }}阶段，产出：{{ phase.output }}"
---
{% extends "base.njk" %}

{% block content %}
<div class="phase-header {{ p.id }}">
  <h1>{{ phase.name }}</h1>
  <div class="question">{{ phase.question }}</div>
  {% if phase.why %}
  <div class="why">{{ phase.why }}</div>
  {% endif %}
</div>

{% if phase.skills %}
<section>
  <div class="section-heading">技能（{{ phase.skills | length }} 个）</div>
  <ul class="skill-list">
    {% for s in phase.skills %}
    <li class="skill-item">
      {% if s.cmd %}<code class="skill-cmd">{{ s.cmd }}</code>{% endif %}
      <span class="skill-name">{{ s.name }}</span>
      {% if s.desc %}<div class="skill-desc">{{ s.desc }}</div>{% endif %}
      {% if s.when %}<div class="skill-when">{{ s.when }}</div>{% endif %}
    </li>
    {% endfor %}
  </ul>
</section>
{% endif %}

{% if phase.output %}
<section>
  <div class="section-heading">产出物</div>
  <ul class="output-list">
    {% for o in phase.output | split(",") %}
    <li>{{ o | trim }}</li>
    {% endfor %}
  </ul>
</section>
{% endif %}

{% if phase.tips %}
<section>
  <div class="section-heading">提示</div>
  <ul class="skill-list">
    {% for t in phase.tips %}
    <li class="skill-item">
      {% if t.cmd %}<code class="skill-cmd">{{ t.cmd }}</code>{% endif %}
      <span class="skill-desc">{{ t.text }}</span>
    </li>
    {% endfor %}
  </ul>
</section>
{% endif %}

{% if phase.prev or phase.next %}
<div class="phase-nav">
  {% if phase.prev %}
  <a href="/{{ phase.prev.id }}/">
    <div class="nav-label">← 上一阶段</div>
    <div class="nav-title">{{ phase.prev.name }}</div>
  </a>
  {% endif %}
  {% if phase.next %}
  <a href="/{{ phase.next.id }}/" style="text-align:right;margin-left:auto;">
    <div class="nav-label">下一阶段 →</div>
    <div class="nav-title">{{ phase.next.name }}</div>
  </a>
  {% endif %}
</div>
{% endif %}

{% if phase.doc %}
<details style="margin-top:24px;font-size:0.875rem;color:var(--text-faint);">
  <summary style="cursor:pointer;">查看原始数据</summary>
  <pre>{{ phase | dump(2) }}</pre>
</details>
{% endif %}
{% endblock %}
