---
pagination:
  data: collections.phasePages
  size: 1
  alias: phase
permalink: "/{{ phase.id }}/index.html"
title: "{{ phase.name }}"
breadcrumb:
  - name: "首页"
    href: "/"
  - name: "{{ phase.name }}"
    href: "{{ page.url }}"
description: "{{ phase.question }} — {{ phase.name }}阶段，产出：{{ phase.output }}"
---
{% extends "base.njk" %}

{% block content %}
<div class="page-header">
  <h1>{{ phase.icon | default("📄") }} {{ phase.name }}</h1>
  <div class="subtitle">{{ phase.question }}</div>
  {% if phase.why %}
  <div class="page-desc">{{ phase.why }}</div>
  {% endif %}
</div>

{% if phase.skills %}
<div class="phase-section">
  <h2>技能（{{ phase.skills | length }} 个）</h2>
  <div class="skill-list">
    {% for s in phase.skills %}
    <div class="skill-item">
      <div class="skill-item-header">
        {% if s.cmd %}<code class="skill-item-cmd">{{ s.cmd }}</code>{% endif %}
        <span class="skill-item-name">{{ s.name }}</span>
      </div>
      {% if s.desc %}<div class="skill-item-desc">{{ s.desc }}</div>{% endif %}
      {% if s.when %}<div class="skill-item-when">{{ s.when }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{% if phase.output %}
<div class="phase-section">
  <h2>产出物</h2>
  <ul class="output-list">
    {% for o in phase.output | split(",") %}
    <li>{{ o | trim }}</li>
    {% endfor %}
  </ul>
</div>
{% endif %}

{% if phase.tips %}
<div class="phase-section">
  <h2>提示</h2>
  <div class="tip-list">
    {% for t in phase.tips %}
    <div class="tip-item">
      {% if t.cmd %}<code class="tip-skill">{{ t.cmd }}</code>{% endif %}
      <span class="tip-desc">{{ t.text }}</span>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{% if phase.prev or phase.next %}
<div class="phase-nav">
  {% if phase.prev %}
  <a href="/{{ phase.prev.id }}/">
    <div class="nav-label">← 上一阶段</div>
    <div class="nav-title">{{ phase.prev.name }}</div>
  </a>
  {% endif %}
  {% if phase.next %}
  <a href="/{{ phase.next.id }}/" style="margin-left:auto;text-align:right;">
    <div class="nav-label">下一阶段 →</div>
    <div class="nav-title">{{ phase.next.name }}</div>
  </a>
  {% endif %}
</div>
{% endif %}

{% if phase.doc %}
<details style="margin-top:24px;font-size:0.875rem;color:var(--ink-faint);">
  <summary style="cursor:pointer;">查看原始数据</summary>
  <pre style="margin-top:8px;padding:16px;background:var(--code-bg);border-radius:4px;overflow:auto;font-size:0.8125rem;">{{ phase | dump(2) }}</pre>
</details>
{% endif %}
{% endblock %}
