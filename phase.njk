---
pagination:
  data: phases
  size: 1
  alias: phase
permalink: "{{ phase.id }}/index.html"
eleventyComputed:
  title: "{{ phase.name }}"
  description: "{{ phase.description }}"
  breadcrumb:
    - name: "{{ phase.name }}"
      href: "/{{ phase.id }}/"
---
{% extends "_includes/base.njk" %}

{% block content %}
<div class="container phase-page">
  <div class="page-header">
    <div class="breadcrumb">
      <a href="/">首页</a>
      <span aria-hidden="true">/</span>
      <span>{{ phase.name }}</span>
    </div>
    <h1>{{ phase.name }}<span class="phase-subtitle"> {{ phase.short }}</span></h1>
    <p class="page-desc">{{ phase.description }}</p>
  </div>

  <!-- 关键问题 -->
  <section class="phase-section">
    <h2>这个阶段回答的关键问题</h2>
    <ul class="question-list">
      {% for q in phase.questions %}
      <li>{{ q }}</li>
      {% endfor %}
    </ul>
  </section>

  <!-- 额外区块（工具页的常用组合） -->
  {% if phase.extraSection %}
  <section class="phase-section">
    <h2>{{ phase.extraSection.title }}</h2>
    <div class="tip-list">
      {% for item in phase.extraSection.items %}
      <div class="tip-item">
        <span class="tip-skill">{{ item.cmd }}</span>
        <span class="tip-desc">{{ item.desc }}</span>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  <!-- 技能工具 -->
  <section class="phase-section">
    <h2>技能工具</h2>
    <div class="skill-list">
      {% for skill in phase.skills %}
      <div class="skill-item">
        <div class="skill-item-header">
          <span class="skill-item-cmd">{{ skill.cmd }}</span>
          <span class="skill-item-name">{{ skill.title }}</span>
        </div>
        <p class="skill-item-desc">{{ skill.desc }}</p>
        <p class="skill-item-when">{{ skill.when }}</p>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- 产出物 -->
  <section class="phase-section">
    <h2>产出物</h2>
    <ul class="output-list-simple">
      {% for output in phase.outputs %}
      <li>{{ output }}</li>
      {% endfor %}
    </ul>
  </section>

  <!-- 前后导航 -->
  <div class="phase-nav">
    {% set prevPhase = phases | find("id", phase.prev) %}
    {% set nextPhase = phases | find("id", phase.next) %}
    {% if prevPhase %}
    <a href="/{{ prevPhase.id }}/">
      <span class="nav-label">← 上一步</span>
      <span class="nav-title">{{ prevPhase.name }}</span>
    </a>
    {% else %}
    <a href="/">
      <span class="nav-label">← 返回</span>
      <span class="nav-title">首页</span>
    </a>
    {% endif %}

    {% if nextPhase %}
    <a href="/{{ nextPhase.id }}/">
      <span class="nav-label">下一步 →</span>
      <span class="nav-title">{{ nextPhase.name }}</span>
    </a>
    {% else %}
    <a href="/">
      <span class="nav-label">回到首页 →</span>
      <span class="nav-title">重新开始新周期</span>
    </a>
    {% endif %}
  </div>
</div>
{% endblock %}
